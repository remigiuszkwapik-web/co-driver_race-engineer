    "@nuxthub/core": "0.10.7",
    "@vueuse/nuxt": "14.2.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "nuxt": "^4.4.2",
    "tailwindcss": "^4.2.1",
    "uplot": "^1.6.32"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
